# CoreInventory Environment Variables
# Copy this file to .env and fill in your values

# Django Secret Key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Debug (False in production)
DEBUG=True

# Allowed Hosts (comma separated, e.g. yourdomain.com,localhost,127.0.0.1)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite is default, update for production PostgreSQL/MySQL)
# DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: DATABASE_URL=postgres://user:password@host:port/dbname

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# CSRF
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Security (production)
SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER=('HTTP_X_FORWARDED_PROTO', 'https')
